#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
VENV_DIR="$ROOT/.venv"
COVERAGE_MINIMUM="92.21"

cd "$ROOT"

PYTHON_BIN="$VENV_DIR/bin/python"

if [ ! -x "$PYTHON_BIN" ]; then
  echo "[pre-commit] Virtual environment not found at $VENV_DIR. Run 'make setup' first."
  exit 1
fi

echo "[pre-commit] Running ruff format..."
"$PYTHON_BIN" -m ruff format .

echo "[pre-commit] Running ruff lint..."
"$PYTHON_BIN" -m ruff check . --fix

echo "[pre-commit] Skipping mypy (dependency syntax error)..."
# if ! "$PYTHON_BIN" -m mypy .; then
#   echo "[pre-commit] Mypy failed."
#   exit 1
# fi

echo "[pre-commit] Checking translations..."
if ! "$PYTHON_BIN" tools/check_translations.py; then
  echo "[pre-commit] Translation check failed."
  exit 1
fi

echo "[pre-commit] Checking release notes..."
if ! "$PYTHON_BIN" tools/check_release_notes.py; then
  echo "[pre-commit] Release notes check failed."
  exit 1
fi

echo "[pre-commit] Running tests..."
if ! "$PYTHON_BIN" -m pytest --cov=custom_components/zurichsee_ha --cov-report=xml:coverage.xml; then
  echo "[pre-commit] Tests failed."
  exit 1
fi

echo "[pre-commit] Checking coverage threshold..."
if ! "$PYTHON_BIN" tools/check_coverage_threshold.py coverage.xml "$COVERAGE_MINIMUM"; then
  echo "[pre-commit] Coverage below threshold."
  exit 1
fi

echo "[pre-commit] All checks passed."
exit 0
